@keyframes alarm-pulse {
  from { opacity: 0.45; transform: scale(0.9); }
  to { opacity: 1; transform: scale(1.08); }
}

@keyframes arrow-up {
  0% { transform: translateY(120rpx) scale(0.8); opacity: 0; }
  35% { opacity: 1; }
  100% { transform: translateY(-170rpx) scale(1.08); opacity: 0; }
}

@keyframes upgrade-pop {
  0% { transform: scale(0.7); opacity: 0; }
  35% { transform: scale(1.12); opacity: 1; }
  100% { transform: scale(1); opacity: 1; }
}

@keyframes ring-burst {
  0% { transform: scale(0.25); opacity: 0; }
  35% { opacity: 1; }
  100% { transform: scale(1.9); opacity: 0; }
}

@keyframes left-clap {
  0% { transform: translateX(-170rpx) rotate(-24deg); opacity: 0; }
  42% { transform: translateX(16rpx) rotate(8deg); opacity: 1; }
  56% { transform: translateX(0) rotate(5deg) scale(1.04); }
  100% { transform: translateX(0) rotate(5deg); opacity: 1; }
}

@keyframes right-clap {
  0% { transform: translateX(170rpx) rotate(24deg); opacity: 0; }
  42% { transform: translateX(-16rpx) rotate(-8deg); opacity: 1; }
  56% { transform: translateX(0) rotate(-5deg) scale(1.04); }
  100% { transform: translateX(0) rotate(-5deg); opacity: 1; }
}

@keyframes line-flash {
  0% { opacity: 0; scale: 0.35; }
  35% { opacity: 1; scale: 1; }
  100% { opacity: 0.65; scale: 1; }
}

@keyframes star-pop {
  0% { opacity: 0; transform: scale(0.2) rotate(0); }
  45% { opacity: 1; transform: scale(1.35) rotate(24deg); }
  100% { opacity: 0.75; transform: scale(1) rotate(8deg); }
}

@keyframes confetti-fall {
  0% { transform: translateY(-40rpx) rotate(0); opacity: 0; }
  18% { opacity: 1; }
  100% { transform: translateY(360rpx) rotate(310deg); opacity: 0.85; }
}

@keyframes ribbon-sweep {
  0% { opacity: 0; scale: 0.4; }
  30% { opacity: 1; scale: 1; }
  100% { opacity: 0.65; scale: 1.06; }
}

@keyframes code-lock {
  0% { transform: translateY(70rpx) scale(0.7); opacity: 0; }
  65% { transform: translateY(0) scale(1.14); opacity: 1; }
  100% { transform: translateY(0) scale(1); opacity: 1; }
}

@keyframes copy-rise {
  0% { transform: translateY(28rpx); opacity: 0; }
  100% { transform: translateY(0); opacity: 1; }
}

@keyframes danger-flash {
  from { filter: brightness(1); }
  to { filter: brightness(1.3); }
}

@keyframes blast-halo-pop {
  0% { transform: scale(0.12); opacity: 0; }
  35% { opacity: 1; }
  100% { transform: scale(1.22); opacity: 0.46; }
}

@keyframes blast-star-pop {
  0% { transform: scale(0.1) rotate(-16deg); opacity: 0; }
  45% { transform: scale(1.12) rotate(4deg); opacity: 1; }
  100% { transform: scale(1) rotate(0); opacity: 1; }
}

@keyframes blast-core-pop {
  0% { transform: scale(0.05); opacity: 0; }
  35% { transform: scale(1.18); opacity: 1; }
  100% { transform: scale(0.96); opacity: 0.92; }
}

@keyframes cloud-pop {
  0% { opacity: 0; scale: 0.15; }
  45% { opacity: 1; scale: 1.12; }
  100% { opacity: 0.94; scale: 1; }
}

@keyframes spark-fly {
  0% { transform: translate(0, 0) scale(0.4); opacity: 0; }
  25% { opacity: 1; }
  100% { transform: translate(var(--spark-x), var(--spark-y)) scale(0.08); opacity: 0; }
}

@keyframes boom-title {
  0% { transform: translateY(80rpx) scale(0.55) rotate(-4deg); opacity: 0; }
  62% { transform: translateY(0) scale(1.16) rotate(2deg); opacity: 1; }
  100% { transform: translateY(0) scale(1) rotate(0); opacity: 1; }
}

@keyframes award-pop {
  0% { transform: translateY(90rpx) scale(0.45) rotate(-10deg); opacity: 0; }
  60% { transform: translateY(0) scale(1.12) rotate(4deg); opacity: 1; }
  100% { transform: translateY(0) scale(1) rotate(0); opacity: 1; }
}

@keyframes award-spin {
  0% { transform: scale(0.3) rotate(0); opacity: 0; }
  35% { opacity: 1; }
  100% { transform: scale(1.3) rotate(180deg); opacity: 0.3; }
}
