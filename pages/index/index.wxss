.page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 48rpx 32rpx;
  background:
    radial-gradient(circle at 78% 8%, rgba(216, 79, 36, 0.22), transparent 24%),
    radial-gradient(circle at 16% 20%, rgba(242, 193, 78, 0.12), transparent 22%),
    linear-gradient(90deg, rgba(255, 255, 255, 0.035) 1px, transparent 1px) 0 0 / 64rpx 64rpx,
    linear-gradient(0deg, rgba(255, 255, 255, 0.035) 1px, transparent 1px) 0 0 / 64rpx 64rpx,
    #0d141c;
  color: #f6ead7;
}

.screen {
  min-height: calc(100vh - 96rpx);
  display: flex;
  flex-direction: column;
  gap: 32rpx;
}

.home-screen {
  justify-content: center;
}

.mute-btn {
  position: absolute;
  top: 8rpx;
  left: -120rpx;
  z-index: 6;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 30rpx;
  height: 50rpx;
  min-height: 0;
  padding: 0;
  border: none;
  background: transparent;
  box-shadow: none;
  opacity: 0.72;
}

.speaker-icon {
  position: relative;
  width: 22rpx;
  height: 20rpx;
  border-left: 8rpx solid #95a3b3;
  border-top: 6rpx solid transparent;
  border-bottom: 6rpx solid transparent;
}

.speaker-icon::before {
  content: "";
  position: absolute;
  left: -20rpx;
  top: 3rpx;
  width: 12rpx;
  height: 14rpx;
  border-radius: 2rpx;
  background: #95a3b3;
}

.speaker-icon::after {
  content: "";
  position: absolute;
  left: 8rpx;
  top: -6rpx;
  width: 28rpx;
  height: 32rpx;
  background:
    radial-gradient(ellipse at left center, transparent 0 8rpx, #95a3b3 9rpx 11rpx, transparent 12rpx),
    radial-gradient(ellipse at left center, transparent 0 16rpx, #95a3b3 17rpx 19rpx, transparent 20rpx);
}

.mute-btn.muted .speaker-icon::after {
  display: none;
}

.mute-btn.muted::after {
  content: "";
  position: absolute;
  width: 34rpx;
  height: 4rpx;
  border-radius: 999rpx;
  background: #95a3b3;
  transform: rotate(-42deg);
}

.medal-home-entry {
  position: absolute;
  top: 6rpx;
  right: -150rpx;
  z-index: 4;
  width: 190rpx;
  min-height: 144rpx;
  padding: 0;
  border: none;
  background: transparent;
  color: #f6ead7;
  line-height: 1.1;
  box-shadow: none;
  overflow: visible;
}

.entry-ribbon,
.medal-ribbon,
.award-ribbon {
  width: 72rpx;
  height: 46rpx;
  margin: 0 auto -10rpx;
  border: 4rpx solid #05070a;
  border-bottom: none;
  border-radius: 24rpx 24rpx 0 0;
  background:
    linear-gradient(90deg, #174f9f 0 24%, #fff8ed 24% 36%, #d84f24 36% 64%, #fff8ed 64% 76%, #174f9f 76%);
}

.entry-medal,
.medal-coin,
.award-medal {
  position: relative;
  width: 78rpx;
  height: 78rpx;
  margin: 0 auto;
  border: 5rpx solid #05070a;
  border-radius: 50%;
  background:
    radial-gradient(circle at 34% 28%, rgba(255, 255, 255, 0.72) 0 10rpx, transparent 11rpx),
    radial-gradient(circle, #f8d76a 0 38%, #c9972e 39% 62%, #8f6013 74%);
  box-shadow: 4rpx 4rpx 0 #05070a, 0 0 26rpx rgba(242, 193, 78, 0.45);
}

.entry-medal::before,
.medal-coin::before,
.award-medal::before {
  content: "";
  position: absolute;
  inset: 10rpx;
  border: 2rpx solid rgba(80, 48, 8, 0.65);
  border-radius: 50%;
}

.entry-star,
.medal-star,
.award-star {
  position: absolute;
  inset: 26rpx;
  background: #8f6013;
  clip-path: polygon(50% 0, 61% 34%, 98% 35%, 68% 56%, 79% 91%, 50% 69%, 21% 91%, 32% 56%, 2% 35%, 39% 34%);
}

.entry-text {
  position: absolute;
  top: 24rpx;
  right: 200rpx;
  width: 22rpx;
  display: flex;
  flex-direction: column;
  gap: 0;
  color: #ffffff;
  font-size: 20rpx;
  font-weight: 900;
  line-height: 1.05;
  text-shadow: 3rpx 3rpx 0 #05070a, 0 0 16rpx rgba(242, 193, 78, 0.45);
}

.medal-home-entry .entry-ribbon {
  margin-left: 32rpx;
  margin-right: 0;
}

.medal-home-entry .entry-medal {
  margin-left: 29rpx;
  margin-right: 0;
}

.entry-text text {
  display: block;
}

.brand-panel,
.input-panel,
.record-list,
.history-table,
.rules-panel,
.learning-panel,
.clue-card,
.device-panel,
.medal-wall {
  border: 4rpx solid #05070a;
  border-radius: 8rpx;
  background:
    linear-gradient(145deg, rgba(255, 255, 255, 0.08), rgba(255, 255, 255, 0)),
    #141f2a;
  box-shadow: 10rpx 10rpx 0 #05070a;
}

.brand-panel {
  position: relative;
  overflow: hidden;
  padding: 52rpx 36rpx 42rpx;
  text-align: center;
}

.brand-panel::before {
  content: "";
  position: absolute;
  inset: 0;
  background:
    linear-gradient(115deg, transparent 0 46%, rgba(216, 79, 36, 0.15) 47% 50%, transparent 51%),
    repeating-linear-gradient(135deg, rgba(242, 193, 78, 0.12) 0 12rpx, transparent 12rpx 28rpx);
  opacity: 0.8;
}

.alarm-light {
  position: absolute;
  top: 24rpx;
  right: 28rpx;
  width: 34rpx;
  height: 34rpx;
  border: 4rpx solid #05070a;
  border-radius: 50%;
  background: #d84f24;
  box-shadow: 0 0 26rpx #d84f24;
  animation: alarm-pulse 900ms infinite alternate;
  z-index: 1;
}

.bomb-core {
  position: relative;
  z-index: 1;
  width: 150rpx;
  height: 150rpx;
  margin: 0 auto 22rpx;
  border: 8rpx solid #05070a;
  border-radius: 50%;
  background:
    radial-gradient(circle at 34% 28%, #586675 0 15rpx, transparent 16rpx),
    radial-gradient(circle at 50% 58%, #05070a, #223140 68%);
}

.fuse {
  position: absolute;
  right: -44rpx;
  top: 4rpx;
  width: 70rpx;
  height: 38rpx;
  border-top: 8rpx solid #f2c14e;
  border-radius: 50%;
  transform: rotate(-25deg);
}

.fuse::after {
  content: "";
  position: absolute;
  right: -14rpx;
  top: -20rpx;
  width: 22rpx;
  height: 22rpx;
  border-radius: 50%;
  background: #d84f24;
  box-shadow: 0 0 24rpx #d84f24;
}

.kicker {
  position: relative;
  z-index: 1;
  color: #f2c14e;
  font-size: 24rpx;
  font-weight: 900;
  letter-spacing: 0;
}

.title {
  position: relative;
  z-index: 1;
  margin-top: 12rpx;
  color: #f6ead7;
  font-size: 76rpx;
  font-weight: 900;
  line-height: 1;
  text-shadow: 6rpx 6rpx 0 #05070a;
}

.countdown {
  position: relative;
  z-index: 1;
  display: inline-block;
  margin-top: 18rpx;
  padding: 10rpx 20rpx;
  border: 4rpx solid #05070a;
  border-radius: 8rpx;
  background: #05070a;
  color: #d84f24;
  font-size: 44rpx;
  font-weight: 900;
  line-height: 1;
}

.subtitle {
  position: relative;
  z-index: 1;
  margin-top: 20rpx;
  color: #b7c2cf;
  font-size: 28rpx;
  line-height: 1.55;
}

.menu {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

button {
  min-height: 88rpx;
  border-radius: 8rpx;
  border: 4rpx solid #05070a;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 88rpx;
}

button::after {
  border: none;
}

.primary-btn {
  background: #d84f24;
  color: #fff8ed;
  box-shadow: 8rpx 8rpx 0 #05070a;
}

.secondary-btn {
  background: #f2c14e;
  color: #0d141c;
  box-shadow: 8rpx 8rpx 0 #05070a;
}

.learn-btn {
  background: #2f7d62;
  color: #fff8ed;
  box-shadow: 8rpx 8rpx 0 #05070a;
}

.ghost-btn {
  background: #1b2836;
  color: #f6ead7;
  box-shadow: 8rpx 8rpx 0 #05070a;
}

.manual-text-link {
  display: inline;
  margin-left: 8rpx;
  color: #f2c14e;
  font-weight: 900;
  text-decoration: underline;
  text-shadow: 0 0 18rpx rgba(242, 193, 78, 0.55);
}

.medal-wall {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 22rpx;
  padding: 28rpx;
}

.medal-card {
  position: relative;
  min-height: 280rpx;
  padding: 18rpx 12rpx 20rpx;
  border: 4rpx solid #05070a;
  border-radius: 8rpx;
  background: #1b2836;
  box-shadow: 6rpx 6rpx 0 #05070a;
  text-align: center;
}

.medal-card.earned {
  background:
    radial-gradient(circle at 50% 20%, rgba(242, 193, 78, 0.28), transparent 48%),
    #1b2836;
}

.medal-card.locked {
  filter: grayscale(1);
  opacity: 0.62;
}

.medal-card.hidden-slot {
  filter: none;
  opacity: 1;
  background:
    repeating-linear-gradient(135deg, rgba(246, 234, 215, 0.04) 0 10rpx, transparent 10rpx 20rpx),
    #162332;
}

.medal-card.locked .medal-coin {
  background:
    radial-gradient(circle at 34% 28%, rgba(255, 255, 255, 0.45) 0 10rpx, transparent 11rpx),
    radial-gradient(circle, #d8dee5, #7d8791 74%);
  box-shadow: 4rpx 4rpx 0 #05070a;
}

.medal-card.hidden-slot .medal-coin {
  opacity: 0.42;
}

.medal-card.hidden-slot .medal-name {
  color: #95a3b3;
}

.medal-count {
  position: absolute;
  bottom: 12rpx;
  right: 12rpx;
  z-index: 2;
  padding: 4rpx 12rpx;
  border: 3rpx solid #05070a;
  border-radius: 999rpx;
  background: #d84f24;
  color: #fff8ed;
  font-size: 22rpx;
  font-weight: 900;
}

.medal-name {
  margin-top: 12rpx;
  color: #f6ead7;
  font-size: 28rpx;
  font-weight: 900;
}

.medal-desc {
  margin-top: 8rpx;
  color: #b7c2cf;
  font-size: 22rpx;
  line-height: 1.35;
}

.topbar {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.section-title {
  margin-top: 8rpx;
  color: #f6ead7;
  font-size: 44rpx;
  font-weight: 900;
  line-height: 1.15;
  text-shadow: 4rpx 4rpx 0 #05070a;
}

.small-btn {
  min-height: 64rpx;
  padding: 0 20rpx;
  background: #f6ead7;
  color: #0d141c;
  font-size: 24rpx;
  line-height: 64rpx;
}

.small-btn.danger {
  background: #d84f24;
  color: #fff8ed;
}

.input-panel,
.rules-panel,
.learning-panel,
.clue-card {
  padding: 32rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.rule-block,
.rule-example {
  padding-bottom: 22rpx;
  border-bottom: 2rpx solid rgba(246, 234, 215, 0.16);
}

.rule-block:last-child {
  padding-bottom: 0;
  border-bottom: none;
}

.rule-title {
  color: #f2c14e;
  font-size: 30rpx;
  font-weight: 900;
}

.rule-text {
  margin-top: 10rpx;
  color: #c5ced8;
  font-size: 27rpx;
  line-height: 1.6;
}

.rule-example {
  border: 4rpx solid #05070a;
  border-radius: 8rpx;
  background: rgba(216, 79, 36, 0.18);
  padding: 24rpx;
}

.progress-number {
  color: #f2c14e;
  font-size: 80rpx;
  font-weight: 900;
  line-height: 1;
}

.mind-map {
  position: relative;
  height: 180rpx;
  margin-top: 26rpx;
  border: 2rpx dashed rgba(246, 234, 215, 0.32);
  border-radius: 8rpx;
}

.mind-map::before,
.mind-map::after {
  content: "";
  position: absolute;
  height: 4rpx;
  background: #f2c14e;
  transform-origin: left center;
}

.mind-map::before {
  width: 230rpx;
  left: 112rpx;
  top: 88rpx;
  transform: rotate(-18deg);
}

.mind-map::after {
  width: 240rpx;
  left: 300rpx;
  top: 92rpx;
  transform: rotate(18deg);
}

.node {
  position: absolute;
  width: 112rpx;
  height: 64rpx;
  border: 4rpx solid #05070a;
  border-radius: 8rpx;
  background: #f6ead7;
  color: #0d141c;
  font-size: 24rpx;
  font-weight: 900;
  line-height: 64rpx;
  text-align: center;
  z-index: 1;
}

.n1 { left: 24rpx; top: 58rpx; }
.n2 { left: 270rpx; top: 20rpx; background: #f2c14e; }
.n3 { right: 24rpx; bottom: 28rpx; background: #2f7d62; color: #fff8ed; }

.level-grid {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 14rpx;
  padding-bottom: 32rpx;
}

.level-card {
  min-height: 112rpx;
  box-sizing: border-box;
  padding: 12rpx 6rpx;
  border: 4rpx solid #05070a;
  border-radius: 8rpx;
  background: #1b2836;
  box-shadow: 4rpx 4rpx 0 #05070a;
  color: #f6ead7;
  text-align: center;
}

.level-card.passed {
  background: #2f7d62;
}

.level-no {
  font-size: 26rpx;
  font-weight: 900;
}

.level-pattern {
  margin-top: 6rpx;
  color: #f2c14e;
  font-size: 20rpx;
  font-weight: 900;
}

.level-state {
  margin-top: 6rpx;
  font-size: 18rpx;
  font-weight: 800;
}

.bomb-rig {
  position: relative;
  min-height: 570rpx;
  margin-bottom: 30rpx;
}

.dynamite {
  position: absolute;
  left: 8rpx;
  right: 8rpx;
  height: 92rpx;
  border: 6rpx solid #05070a;
  border-radius: 46rpx;
  background:
    linear-gradient(90deg, rgba(255, 255, 255, 0.18), transparent 18% 82%, rgba(0, 0, 0, 0.28)),
    repeating-linear-gradient(90deg, transparent 0 72rpx, rgba(0, 0, 0, 0.24) 72rpx 82rpx),
    #c94732;
  box-shadow: inset 0 -12rpx 0 rgba(0, 0, 0, 0.18);
}

.tube-one {
  top: 56rpx;
  transform: rotate(-1deg);
}

.tube-two {
  top: 132rpx;
  background:
    linear-gradient(90deg, rgba(255, 255, 255, 0.14), transparent 18% 82%, rgba(0, 0, 0, 0.28)),
    repeating-linear-gradient(90deg, transparent 0 72rpx, rgba(0, 0, 0, 0.24) 72rpx 82rpx),
    #b93d31;
  transform: rotate(1deg);
}

.strap {
  position: absolute;
  top: 44rpx;
  width: 58rpx;
  height: 190rpx;
  border: 6rpx solid #05070a;
  background: repeating-linear-gradient(135deg, #8f7f52 0 12rpx, #2b3036 12rpx 24rpx);
  z-index: 1;
}

.strap-left {
  left: 70rpx;
}

.strap-right {
  right: 58rpx;
}

.coil-line {
  position: absolute;
  left: 18rpx;
  top: 10rpx;
  width: 160rpx;
  height: 56rpx;
  border-top: 16rpx dotted #526170;
  border-radius: 50%;
  transform: rotate(-10deg);
  z-index: 2;
  filter: drop-shadow(3rpx 4rpx 0 #05070a);
}

.top-wire {
  position: absolute;
  height: 12rpx;
  border: 4rpx solid #05070a;
  border-radius: 999rpx;
  z-index: 3;
}

.green-wire {
  top: 28rpx;
  left: 330rpx;
  width: 180rpx;
  background: #2fd17c;
  transform: rotate(15deg);
}

.yellow-wire {
  top: 52rpx;
  left: 388rpx;
  width: 200rpx;
  background: #f2c14e;
  transform: rotate(7deg);
}

.red-wire {
  top: 46rpx;
  left: 198rpx;
  width: 112rpx;
  background: #d84f24;
  transform: rotate(-18deg);
}

.control-board {
  position: absolute;
  left: 28rpx;
  right: 28rpx;
  top: 104rpx;
  min-height: 420rpx;
  padding: 34rpx 28rpx 28rpx;
  border: 7rpx solid #05070a;
  border-radius: 16rpx;
  background:
    linear-gradient(135deg, rgba(255, 255, 255, 0.08), transparent),
    #2a333c;
  box-shadow: 10rpx 12rpx 0 #05070a;
  z-index: 4;
}

.screw {
  position: absolute;
  width: 20rpx;
  height: 20rpx;
  border: 3rpx solid #05070a;
  border-radius: 50%;
  background: #bdc4ca;
}

.screw::after {
  content: "";
  position: absolute;
  left: 3rpx;
  right: 3rpx;
  top: 8rpx;
  height: 3rpx;
  background: #05070a;
  transform: rotate(-25deg);
}

.screw-one { left: 12rpx; top: 12rpx; }
.screw-two { right: 12rpx; top: 12rpx; }
.screw-three { left: 12rpx; bottom: 12rpx; }
.screw-four { right: 12rpx; bottom: 12rpx; }

.board-top {
  display: grid;
  grid-template-columns: 120rpx 1fr 148rpx;
  gap: 18rpx;
  align-items: center;
  margin-bottom: 20rpx;
}

.component-cluster {
  display: grid;
  grid-template-columns: 72rpx 32rpx;
  gap: 12rpx;
  align-items: center;
}

.knob {
  width: 72rpx;
  height: 72rpx;
  border: 5rpx solid #05070a;
  border-radius: 50%;
  background:
    radial-gradient(circle at 35% 30%, #808993 0 12rpx, transparent 13rpx),
    #50565d;
}

.led-dot {
  width: 28rpx;
  height: 28rpx;
  border: 4rpx solid #05070a;
  border-radius: 50%;
  background: #d84f24;
  box-shadow: 0 0 16rpx #d84f24;
}

.circuit-stack {
  display: grid;
  gap: 12rpx;
}

.chip {
  height: 52rpx;
  border: 4rpx solid #05070a;
  border-radius: 6rpx;
  background:
    repeating-linear-gradient(90deg, #8e9aa4 0 7rpx, transparent 7rpx 16rpx),
    #111820;
}

.resistor {
  height: 20rpx;
  border: 4rpx solid #05070a;
  border-radius: 999rpx;
  background:
    linear-gradient(90deg, #d8b56a 0 18%, #05070a 18% 25%, #d8b56a 25% 56%, #d84f24 56% 63%, #d8b56a 63%);
}

.timer-chip {
  padding: 14rpx 10rpx;
  border: 5rpx solid #05070a;
  border-radius: 8rpx;
  background: #051115;
  color: #d84f24;
  font-size: 32rpx;
  font-weight: 900;
  text-align: center;
}

.clue-card {
  padding: 24rpx;
}

.clue-line {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-top: 12rpx;
}

.clue-number,
.clue-result {
  font-size: 48rpx;
  font-weight: 900;
  line-height: 1;
}

.clue-number {
  color: #f6ead7;
}

.clue-result {
  color: #f2c14e;
}

.guess-area {
  display: block;
  border: 4rpx solid #05070a;
  border-radius: 8rpx;
  background:
    linear-gradient(90deg, rgba(255, 255, 255, 0.035) 1px, transparent 1px) 0 0 / 64rpx 64rpx,
    linear-gradient(0deg, rgba(255, 255, 255, 0.035) 1px, transparent 1px) 0 0 / 64rpx 64rpx,
    #111b25;
  box-shadow: 10rpx 10rpx 0 #05070a;
  padding: 24rpx;
}

.guess-row {
  display: grid;
  grid-template-columns: 1fr;
  gap: 18rpx;
}

.input-shell {
  border: 4rpx solid #05070a;
  border-radius: 8rpx;
  background: #05070a;
  box-shadow: inset 0 0 0 2rpx rgba(47, 209, 124, 0.18);
  overflow: hidden;
}

.terminal-label {
  display: flex;
  justify-content: space-between;
  padding: 16rpx 22rpx 0;
  color: #f2c14e;
  font-size: 24rpx;
  font-weight: 900;
}

.password-input {
  height: 88rpx;
  box-sizing: border-box;
  padding: 0 24rpx;
  border: 4rpx solid #05070a;
  border-radius: 8rpx;
  background: #05070a;
  color: #2fd17c;
  font-size: 36rpx;
  font-weight: 900;
  letter-spacing: 0;
}

.crack-input {
  position: absolute;
  inset: 0;
  z-index: 3;
  width: 100%;
  height: 174rpx;
  box-sizing: border-box;
  padding: 0;
  border: none;
  border-radius: 0;
  background: transparent;
  color: transparent;
  caret-color: transparent;
  opacity: 0.01;
}

.digit-display {
  position: absolute;
  inset: 0;
  z-index: 1;
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  align-items: center;
  justify-items: center;
  padding: 0 22rpx;
  pointer-events: none;
}

.digit-cell {
  min-width: 42rpx;
  color: #45ffe2;
  font-family: "DSEG7 Classic", "DS-Digital", "Digital-7 Mono", "LCD", "Roboto Mono", "Consolas", monospace;
  font-size: 82rpx;
  font-weight: 900;
  line-height: 1;
